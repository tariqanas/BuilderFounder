# Public Supabase client config (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-side Supabase config (never expose)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx

# Make.com endpoint auth keys (can be same value if you want one shared secret)
MAKE_INGEST_KEY=change-me
MAKE_NOTIFY_KEY=change-me

# Internal job/ops keys
JOBS_API_KEY=change-me
CRON_KEY=change-me
HEALTH_KEY=change-me

# Public app URL used for Stripe redirects and callback links
APP_URL=https://app.example.com

# Dev-only seed and matching endpoints
DEV_SEED_SECRET=change-me-dev-secret

# Optional AI settings (OPENAI_API_KEY required only if AI matching is enabled)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MAX_AI_CALLS_PER_RUN=300
SIMULATE_USERS=0
MATCH_SCORE_THRESHOLD=70
